      "destination": "/projects/",
      "permanent": true
    },
    {
      "source": "/hackathon/",
      "destination": "/projects/",
      "permanent": true
    },
    {
      "source": "/hackathon/project/:slug",
      "destination": "/projects/project/:slug/",
      "permanent": true
    },
    {
      "source": "/hackathon/project/:slug/",
      "destination": "/projects/project/:slug/",
      "permanent": true
    },
    {
      "source": "/hackathon/team/:slug",
      "destination": "/projects/team/:slug/",
      "permanent": true
    },
    {
      "source": "/hackathon/team/:slug/",
      "destination": "/projects/team/:slug/",
      "permanent": true
    },
    {
      "source": "/:path((?!.*\\.).*[^/])",
