---
import { EVENT } from "../data/event";
import { SECTION_ANCHORS, withBase } from "../data/nav";
import { SOCIAL_LINKS } from "../data/socials";
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-info">
          <h3 class="footer-logo">HACKMI</h3>
          <p class="footer-tagline">{EVENT.tagline}</p>
          <p class="footer-event-details">
            {EVENT.location}<br />
            {EVENT.date}
          </p>
        </div>

        <div class="footer-links">
          <h4 class="footer-title">Navigation</h4>
          <ul>
            {
              SECTION_ANCHORS.map((a) => (
                <li>
                  <a href={withBase(base, a.href)}>{a.footer}</a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer-social">
          <h4 class="footer-title">Connect</h4>
          <ul>
            {
              SOCIAL_LINKS.map((s) => (
                <li>
                  <a href={s.href} target="_blank" rel="noopener noreferrer">
                    {s.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; {currentYear} {EVENT.name}. All rights reserved.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .sponsor-strip {
    padding: 2rem 1.5rem 0;
    border-top: 1px solid var(--color-border);
    background: rgb(15 23 42 / 50%);
  }

  .sponsor-strip-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    text-align: center;
  }

  .sponsor-strip-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .sponsor-strip-logos {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem 2rem;
    padding-bottom: 2rem;
  }

  :global(.sponsor-strip-link) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
    transition: opacity var(--duration-fast) ease;
  }

  :global(a.sponsor-strip-link:hover) {
    opacity: 1;
  }

  .sponsor-strip-img {
    max-height: 120px;
    width: auto;
    max-width: 240px;
    object-fit: contain;
    filter: grayscale(0.15) brightness(1.05);
  }

  :global(a.sponsor-strip-link:hover) .sponsor-strip-img {
    filter: grayscale(0) brightness(1.1);
  }

  .footer {
    position: relative;
    z-index: 10;
  }

  .footer-main {
    padding: 4rem 2rem 3rem;
    background: rgb(15 23 42 / 90%);
    border-top: 1px solid var(--color-border);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .footer-logo {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .footer-tagline {
    color: var(--color-text-dim);
    margin-bottom: 1.5rem;
    max-width: 300px;
  }

  .footer-event-details {
    color: var(--color-accent-orange-hover);
    font-weight: 500;
  }

  .footer-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .footer-links ul,
  .footer-social ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li,
  .footer-social li {
    margin-bottom: 0.75rem;
  }

  .footer-links a,
  .footer-social a {
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .footer-links a:hover,
  .footer-social a:hover {
    color: var(--color-accent-orange-hover);
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgb(255 255 255 / 5%);
    text-align: center;
    color: var(--color-text-dim);
    font-size: 0.9rem;
  }

  @media (max-width: 48rem) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-main {
      padding: 3rem 1.5rem 2rem;
    }
  }
</style>
