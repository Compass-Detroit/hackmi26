---
import { publicAssetUrl, siteHeaderBrand } from "../data/siteLogos";
import { SECTION_ANCHORS, PRIMARY_CTA, withBase } from "../data/nav";

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const relativePath = currentPath.replace(base.slice(0, -1), "") || "/";

const brand = siteHeaderBrand;
const homeLabel = `${brand.logoAlt} — Home`;
const wordmark = "wordmark" in brand ? brand.wordmark : undefined;

/**
 * Single source of truth for nav entries. Rendered identically in the
 * desktop bar and the mobile overlay (with variant-specific class names).
 */
type NavItem = {
  href: string;
  label: string;
  active?: boolean;
  external?: boolean;
  cta?: "primary"; // primary CTA (sponsor) -- mobile uses long label
};

const navItems: NavItem[] = [
  { href: base, label: "Home", active: relativePath === "/" },
  {
    href: withBase(base, "/projects/"),
    label: "Projects",
    active:
      relativePath.startsWith("/projects") || relativePath.startsWith("/hackathon"),
  },
  ...SECTION_ANCHORS.map((a) => ({
    href: withBase(base, a.href),
    label: a.nav,
  })),
  {
    href: PRIMARY_CTA.hacker.href,
    label: PRIMARY_CTA.hacker.label,
    external: true,
  },
];

const desktopCta = PRIMARY_CTA.sponsor;
const mobileCta = PRIMARY_CTA.sponsorLong;
---

<nav class="site-nav" id="site-navigation" aria-label="Main navigation">
  <div class="nav">
    <div class="nav-container">
      <div class="nav-brand">
        <a href={base} class="logo" aria-label={homeLabel}>
          <img
            class="site-logo-img"
            src={publicAssetUrl(base, brand.logoSrc)}
            alt={wordmark ? "" : brand.logoAlt}
            loading="eager"
            decoding="async"
          />
          {wordmark && <span class="logo-wordmark">{wordmark}</span>}
        </a>
      </div>

      <div class="nav-links">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "nav-link",
                { active: item.active, "nav-link-external": item.external },
              ]}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noopener noreferrer" : undefined}
            >
              {item.label}
            </a>
          ))
        }
        <a href={desktopCta.href} class="nav-cta">{desktopCta.label}</a>
      </div>

      <button
        class="mobile-menu-btn"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
        id="mobile-menu-btn"
      >
        <svg
          class="hamburger-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div
    class="mobile-menu"
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation menu"
    aria-hidden="true"
    inert
  >
    <div class="mobile-menu-content">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={["mobile-nav-link", { active: item.active }]}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noopener noreferrer" : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <a href={mobileCta.href} class="mobile-nav-cta">{mobileCta.label}</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 1000;
    padding: 1rem 1.5rem;
    background: rgb(15 23 42 / 92%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    animation: slide-down 0.5s var(--ease-out);
    text-transform: uppercase;
  }

  .nav-container {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.05em;
    color: var(--color-text);
    transition: color var(--duration-fast) ease;
  }

  .site-logo-img {
    flex-shrink: 0;
    height: 48px;
    width: auto;
    max-width: 240px;
    object-fit: contain;
    display: block;
  }

  .logo-wordmark {
    white-space: nowrap;
  }

  .logo:hover .logo-wordmark {
    color: var(--color-accent-orange);
  }

  .logo:hover {
    color: var(--color-accent-orange-hover);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-link {
    color: var(--color-text-dim);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    position: relative;
    transition: color var(--duration-fast) ease;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent-orange);
    transition: width var(--duration-fast) ease;
  }

  .nav-link:hover {
    color: var(--color-accent-orange-hover);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--color-accent-orange-hover);
  }

  .nav-link-external {
    color: var(--color-text);
  }

  .nav-cta {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 600;
    color: #000;
    background: var(--color-accent-orange);
    text-decoration: none;
    transition:
      background-color var(--duration-fast) ease,
      box-shadow var(--duration-fast) ease;
    white-space: nowrap;
  }

  .nav-cta:hover {
    background: var(--color-accent-orange-hover);
    box-shadow: var(--shadow-sm);
  }

  .mobile-menu-btn {
    display: none;
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-menu-btn .hamburger-icon {
    width: 24px;
    height: 24px;
  }

  .mobile-menu {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgb(15 23 42 / 98%);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-base) ease;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 1.5rem;
    padding: 2rem;
  }

  .mobile-nav-link {
    font-family: var(--font-heading);
    font-size: 1.65rem;
    font-weight: 600;
    color: var(--color-accent-orange-hover);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-accent-orange-hover);
  }

  .mobile-nav-cta {
    margin-top: 0.5rem;
    padding: 0.85rem 1.75rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: #000;
    background: var(--color-accent-orange);
    text-decoration: none;
  }

  @media (max-width: 64rem) {
    .nav-links {
      gap: 0.75rem;
    }

    .nav-link {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 48rem) {
    .nav {
      top: 0.75rem;
      left: 0.75rem;
      right: 0.75rem;
      padding: 0.875rem 1rem;
    }

    .site-logo-img {
      height: 36px;
      max-width: 160px;
    }

    .nav-links {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const FOCUSABLE_SELECTOR =
    'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu) return;
    if (btn.dataset.mobileMenuBound === "true") return;
    btn.dataset.mobileMenuBound = "true";

    function getFocusable(): HTMLElement[] {
      return Array.from(
        menu!.querySelectorAll<HTMLElement>(FOCUSABLE_SELECTOR),
      );
    }

    function focusFirstMenuItem() {
      const tryFocus = () => {
        const first = getFocusable()[0];
        if (!first) return false;
        first.focus({ preventScroll: true });
        return document.activeElement === first;
      };

      // Try immediately, then after paint, then after micro-delay.
      if (tryFocus()) return;
      requestAnimationFrame(() => {
        if (tryFocus()) return;
        window.setTimeout(() => {
          tryFocus();
        }, 0);
      });
    }

    function setOpen(open: boolean) {
      menu!.classList.toggle("open", open);
      menu!.setAttribute("aria-hidden", String(!open));
      btn!.setAttribute("aria-expanded", String(open));
      btn!.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      document.body.style.overflow = open ? "hidden" : "";

      // Use `inert` to remove menu from tab order + a11y tree when closed.
      if (open) {
        menu!.removeAttribute("inert");
        document.addEventListener("keydown", onKeydown);
        // Focus the first link for screen-reader + keyboard users.
        focusFirstMenuItem();
      } else {
        menu!.setAttribute("inert", "");
        document.removeEventListener("keydown", onKeydown);
      }
    }

    function onKeydown(e: KeyboardEvent) {
      if (e.key === "Escape") {
        setOpen(false);
        btn!.focus();
        return;
      }
      if (e.key !== "Tab") return;

      // Focus trap: cycle within the menu.
      const focusable = getFocusable();
      if (focusable.length === 0) return;
      const first = focusable[0]!;
      const last = focusable[focusable.length - 1]!;
      const active = document.activeElement as HTMLElement | null;

      if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      }
    }

    btn.addEventListener("click", () => {
      const isOpen = menu.classList.contains("open");
      setOpen(!isOpen);
      if (!menu.classList.contains("open")) btn.focus();
    });

    const mobileLinks = menu.querySelectorAll(
      ".mobile-nav-link, .mobile-nav-cta",
    );
    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMobileMenu, {
      once: true,
    });
  } else {
    initMobileMenu();
  }

  document.addEventListener("astro:page-load", initMobileMenu);
</script>
