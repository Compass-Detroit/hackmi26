---
import {
  publicAssetUrl,
  siteHeaderBrand,
} from "../data/siteLogos";
import { EXTERNAL_URLS } from "../lib/constants";

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const relativePath = currentPath.replace(base.slice(0, -1), "") || "/";

const brand = siteHeaderBrand;
const homeLabel = `${brand.logoAlt} — Home`;
const wordmark = "wordmark" in brand ? brand.wordmark : undefined;
---

<nav class="nav">
  <div class="nav-container">
    <div class="nav-brand">
      <a href={base} class="logo" aria-label={homeLabel}>
        <img
          class="site-logo-img"
          src={publicAssetUrl(base, brand.logoSrc)}
          alt={wordmark ? "" : brand.logoAlt}
          loading="eager"
          decoding="async"
        />
        {wordmark && <span class="logo-wordmark">{wordmark}</span>}
      </a>
    </div>

    <div class="nav-links">
      <a
        href={base}
        class:list={["nav-link", { active: relativePath === "/" }]}
      >
        Home
      </a>
      <a href={`${base}#about`} class="nav-link">About</a>
      <a href={`${base}#sponsors`} class="nav-link">Sponsors</a>
      <a href={`${base}#event-details`} class="nav-link">Event</a>
      <a href={`${base}#logistics`} class="nav-link">Logistics</a>
      <a
        href={EXTERNAL_URLS.HACKER_REGISTRATION}
        class="nav-link nav-link-external"
        target="_blank"
        rel="noopener noreferrer"
      >
        Register
      </a>
      <a
        href={EXTERNAL_URLS.SPONSOR_INQUIRY}
        class="nav-cta"
        target="_blank"
        rel="noopener noreferrer">Sponsor</a
      >
    </div>

    <button
      class="mobile-menu-btn"
      aria-label="Toggle menu"
      id="mobile-menu-btn"
    >
      <svg
        class="icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu-content">
    <a
      href={base}
      class:list={["mobile-nav-link", { active: relativePath === "/" }]}>Home</a
    >
    <a href={`${base}#about`} class="mobile-nav-link">About</a>
    <a href={`${base}#sponsors`} class="mobile-nav-link">Sponsors</a>
    <a href={`${base}#event-details`} class="mobile-nav-link">Event</a>
    <a href={`${base}#logistics`} class="mobile-nav-link">Logistics</a>
    <a
      href={EXTERNAL_URLS.HACKER_REGISTRATION}
      class="mobile-nav-link"
      target="_blank"
      rel="noopener noreferrer">Register</a
    >
    <a
      href={EXTERNAL_URLS.SPONSOR_INQUIRY}
      class="mobile-nav-cta"
      target="_blank"
      rel="noopener noreferrer">Become a sponsor</a
    >
  </div>
</div>

<style>
  .nav {
    position: fixed;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 1000;
    padding: 1rem 1.5rem;
    background: rgba(15, 23, 42, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    animation: slideDown 0.5s ease-out;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.05em;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .site-logo-img {
    flex-shrink: 0;
    height: 48px;
    width: auto;
    max-width: 240px;
    object-fit: contain;
    display: block;
  }

  .logo-wordmark {
    white-space: nowrap;
  }

  .logo:hover .logo-wordmark {
    color: var(--color-primary);
  }

  .logo:hover {
    color: var(--color-primary);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-link {
    color: var(--color-text-dim);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    position: relative;
    transition: color 0.2s ease;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary-button);
    transition: width 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--color-primary);
  }

  .nav-link-external {
    color: var(--color-text);
  }

  .nav-cta {
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    background: var(--color-primary-button);
    text-decoration: none;
    transition:
      background: 0.2s ease,
      box-shadow: 0.2s ease;
    white-space: nowrap;
  }

  .nav-cta:hover {
    background: #2563eb;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.35);
  }

  .mobile-menu-btn {
    display: none;
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-menu-btn .icon {
    width: 24px;
    height: 24px;
  }

  .mobile-menu {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.98);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 1.5rem;
    padding: 2rem;
  }

  .mobile-nav-link {
    font-family: var(--font-heading);
    font-size: 1.65rem;
    font-weight: 600;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-primary);
  }

  .mobile-nav-cta {
    margin-top: 0.5rem;
    padding: 0.85rem 1.75rem;
    border-radius: 0.5rem;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    background: var(--color-primary-button);
    text-decoration: none;
  }

  @keyframes slideDown {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media (max-width: 1024px) {
    .nav-links {
      gap: 0.75rem;
    }

    .nav-link {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 768px) {
    .nav {
      top: 0.75rem;
      left: 0.75rem;
      right: 0.75rem;
      padding: 0.875rem 1rem;
    }

    .site-logo-img {
      height: 36px;
      max-width: 160px;
    }

    .nav-org-logo-img {
      max-height: 22px;
      max-width: 90px;
    }

    .nav-links {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("open");
      });

      const mobileLinks = mobileMenu.querySelectorAll(
        ".mobile-nav-link, .mobile-nav-cta",
      );
      mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.remove("open");
        });
      });
    }
  });
</script>
