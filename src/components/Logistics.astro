<section id="logistics" class="logistics">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Logistics & Clarity</h2>
      <p class="section-subtitle">Technical guidelines for all participants.</p>
    </div>

    <div class="logistics-grid">
      <div class="logistics-section">
        <h3 class="logistics-title">Rules</h3>
        <ul class="logistics-list">
          <li>Original work only. No pre-built projects allowed.</li>
          <li>Teams are limited to a maximum of 4 developers.</li>
          <li>All code must be committed to a public GitHub repository.</li>
          <li>Adherence to the Hack Michigan Code of Conduct is mandatory.</li>
        </ul>
      </div>

      <div class="logistics-section">
        <h3 class="logistics-title">Prizes</h3>
        <ul class="logistics-list">
          <li><strong>Grand Prize:</strong> $5,000 + Engineering Mentorship</li>
          <li><strong>Agentic Systems Track:</strong> $2,500 + API Credits</li>
          <li>
            <strong>Infrastructure Track:</strong> $2,500 + Hardware Access
          </li>
          <li><strong>Community Award:</strong> Local Ecosystem Visibility</li>
        </ul>
      </div>

      <div class="logistics-section">
        <h3 class="logistics-title">Judging Criteria</h3>
        <ul class="logistics-list">
          <li>
            <strong>Technical Complexity:</strong> Depth of engineering skill.
          </li>
          <li>
            <strong>Impact:</strong> Real-world utility and problem-solving.
          </li>
          <li>
            <strong>Execution:</strong> Polish, performance, and stability.
          </li>
          <li>
            <strong>Innovation:</strong> Novel approach to existing challenges.
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .logistics {
    padding: 6rem 2rem;
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .section-subtitle {
    color: var(--color-text-dim);
    font-size: 1.1rem;
  }

  .logistics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .logistics-section {
    background: rgba(59, 130, 246, 0.05);
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 2.5rem;
    transition: all 0.3s ease;
  }

  .logistics-section:hover {
    border-color: var(--color-primary);
    background: rgba(59, 130, 246, 0.08);
  }

  .logistics-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }

  .logistics-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .logistics-list li {
    color: var(--color-text-dim);
    line-height: 1.6;
    margin-bottom: 1rem;
    position: relative;
    padding-left: 1.5rem;
  }

  .logistics-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: bold;
  }

  .logistics-list li strong {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .logistics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
