---
import { EXTERNAL_URLS } from "../lib/constants";
---

<section class="final-cta">
  <div class="container">
    <div class="cta-card">
      <h2 class="cta-title">Ready to Build?</h2>
      <p class="cta-description">
        Join 500+ engineers in Detroit for the most technical event of the year.
        Registration is now open through the IBM Agentic platform.
      </p>
      <div class="cta-buttons">
        <a
          href={EXTERNAL_URLS.HACKER_REGISTRATION}
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Register on IBM Agentic
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 8rem 2rem;
    position: relative;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .cta-card {
    background: linear-gradient(135deg, var(--color-primary) 0%, #1e40af 100%);
    border-radius: 2rem;
    padding: 5rem 3rem;
    text-align: center;
    box-shadow: 0 20px 50px rgba(59, 130, 246, 0.3);
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.1) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: white;
    letter-spacing: -0.02em;
  }

  .cta-description {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 1.25rem 2.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    background: white;
    color: var(--color-primary-button);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 768px) {
    .cta-card {
      padding: 4rem 2rem;
    }
  }
</style>
