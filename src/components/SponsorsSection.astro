---
import SponsorCTA from './SponsorCTA.astro';

const platinumSlots = [1, 2, 3] as const;
const communitySlots = [1, 2, 3, 4] as const;
const platinumSlotTotal = platinumSlots.length;
const communitySlotTotal = communitySlots.length;
---

<section class="sponsors-section" id="sponsors" aria-labelledby="sponsors-heading">
  <div class="container">
    <h2 id="sponsors-heading" class="section-title">Sponsors</h2>
    <p class="section-subtitle">
      Thank you to the organizations backing HackMI. Interested in joining them?
    </p>

    <div class="sponsor-tiers">
      <section class="sponsor-tier sponsor-tier--gold" aria-labelledby="tier-gold-heading">
        <h3 id="tier-gold-heading" class="tier-heading">Gold</h3>
        <ul class="tier-slots tier-slots--gold">
          <li class="sponsor-slot sponsor-slot--card" aria-label="Gold sponsor — logo placeholder">
            <span class="sponsor-slot__plus" aria-hidden="true">+</span>
          </li>
        </ul>
      </section>

      <section class="sponsor-tier sponsor-tier--platinum" aria-labelledby="tier-platinum-heading">
        <h3 id="tier-platinum-heading" class="tier-heading">Platinum</h3>
        <ul class="tier-slots tier-slots--platinum">
          {platinumSlots.map((n) => (
            <li
              class="sponsor-slot sponsor-slot--card"
              aria-label={`Platinum sponsor slot ${n} of ${platinumSlotTotal} — logo placeholder`}
            >
              <span class="sponsor-slot__plus" aria-hidden="true">+</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="sponsor-tier sponsor-tier--community" aria-labelledby="tier-community-heading">
        <h3 id="tier-community-heading" class="tier-heading">Community</h3>
        <ul class="tier-slots tier-slots--community">
          {communitySlots.map((n) => (
            <li
              class="sponsor-slot sponsor-slot--square"
              aria-label={`Community sponsor slot ${n} of ${communitySlotTotal} — logo placeholder`}
            >
              <span class="sponsor-slot__plus" aria-hidden="true">+</span>
            </li>
          ))}
        </ul>
      </section>
    </div>

    <SponsorCTA />
  </div>
</section>

<style>
  .sponsors-section {
    padding: 2rem 2rem 5rem;
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-dim);
    text-transform: uppercase;
    font-size: 1.1rem;
    margin-bottom: 2rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .sponsor-tiers {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .sponsor-tier {
    width: 100%;
  }

  .tier-heading {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-align: center;
    margin-bottom: 1rem;
  }

  .tier-slots {
    display: grid;
    gap: 1rem;
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Gold: single row, one business-card slot (centered) */
  .tier-slots--gold {
    grid-template-columns: 1fr;
    justify-items: center;
    max-width: min(400px, 100%);
    margin: 0 auto;
  }

  /* Platinum: three across */
  .tier-slots--platinum {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  /* Community: four across */
  .tier-slots--community {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .sponsor-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    box-sizing: border-box;
    border-radius: 0.75rem;
    border: 1px dashed rgba(148, 163, 184, 0.45);
    background: rgba(15, 23, 42, 0.5);
    transition:
      border-color 0.2s ease,
      background 0.2s ease;
  }

  /* 3.5″ × 2″ business card (landscape) */
  .sponsor-slot--card {
    aspect-ratio: 7 / 4;
  }

  .sponsor-slot--square {
    aspect-ratio: 1 / 1;
  }

  .sponsor-slot:hover {
    border-color: rgba(59, 130, 246, 0.55);
    background: rgba(30, 41, 59, 0.55);
  }

  .sponsor-slot__plus {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 500;
    line-height: 1;
    color: rgba(148, 163, 184, 0.55);
    user-select: none;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .tier-slots--community {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .tier-slots--platinum {
      grid-template-columns: 1fr;
    }

    .tier-slots--community {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sponsors-section {
      padding: 1.5rem 1.25rem 4rem;
    }
  }
</style>
