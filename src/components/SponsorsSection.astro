---
import SponsorCTA from './SponsorCTA.astro';
---

<section class="sponsors-section" id="sponsors" aria-labelledby="sponsors-heading">
  <div class="container">
    <h2 id="sponsors-heading" class="section-title">Sponsors</h2>
    <p class="section-subtitle">
      Thank you to the organizations backing HackMI. Interested in joining them?
    </p>

    <div class="tier-grid" role="list">
      <article class="tier-card glass" role="listitem">
        <p class="tier-label">Platinum</p>
        <h3 class="tier-name">Partner name</h3>
        <p class="tier-copy">Logo and details will appear here when sponsors are confirmed.</p>
        <div class="tier-placeholder" aria-hidden="true" />
      </article>
      <article class="tier-card glass" role="listitem">
        <p class="tier-label">Gold</p>
        <h3 class="tier-name">Partner name</h3>
        <p class="tier-copy">Logo and details will appear here when sponsors are confirmed.</p>
        <div class="tier-placeholder" aria-hidden="true" />
      </article>
      <article class="tier-card glass" role="listitem">
        <p class="tier-label">Community</p>
        <h3 class="tier-name">Partner name</h3>
        <p class="tier-copy">Logo and details will appear here when sponsors are confirmed.</p>
        <div class="tier-placeholder" aria-hidden="true" />
      </article>
    </div>

    <SponsorCTA />
  </div>
</section>

<style>
  .sponsors-section {
    padding: 2rem 2rem 5rem;
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-dim);
    font-size: 1.1rem;
    margin-bottom: 2rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .tier-card {
    border-radius: 1rem;
    padding: 1.75rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .glass {
    background: rgba(30, 41, 59, 0.55);
    border: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .tier-card:hover {
    border-color: rgba(59, 130, 246, 0.45);
    box-shadow: 0 12px 40px rgba(59, 130, 246, 0.12);
  }

  .tier-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .tier-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .tier-copy {
    font-size: 0.95rem;
    color: var(--color-text-dim);
    line-height: 1.55;
    margin-bottom: 1.25rem;
  }

  .tier-placeholder {
    height: 72px;
    border-radius: 0.5rem;
    border: 1px dashed var(--color-border);
    background: rgba(15, 23, 42, 0.4);
  }

  @media (max-width: 768px) {
    .sponsors-section {
      padding: 1.5rem 1.25rem 4rem;
    }
  }
</style>
