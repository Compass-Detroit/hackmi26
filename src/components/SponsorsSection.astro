---
import SponsorCTA from "./SponsorCTA.astro";
import SponsorTier from "./SponsorTier.astro";
import BuiltByRow from "./BuiltByRow.astro";
import { sponsorLogosByTier, type SponsorTierKey } from "../data/sponsorLogos";
import Section from "./primitives/Section.astro";
import SectionHeader from "./primitives/SectionHeader.astro";

/**
 * Display config for each sponsor tier — single source of truth.
 * To add a tier: append one entry here (and add its key to SponsorTierKey).
 * `totalSlots` sets visible grid slots; extras over logos.length render as `+` placeholders.
 * When omitted it defaults to logos.length (no open-slot placeholders shown).
 */
const TIER_DISPLAY: Array<{
  key: SponsorTierKey;
  heading: string;
  totalSlots?: number;
  shape: "card" | "square";
}> = [
  { key: "diamond", heading: "Diamond", shape: "card" },
  { key: "platinum", heading: "Platinum", totalSlots: 3, shape: "card" },
  { key: "gold", heading: "Gold", totalSlots: 4, shape: "card" },
  { key: "community", heading: "Community", totalSlots: 8, shape: "square" },
  { key: "media", heading: "Media", totalSlots: 4, shape: "square" },
];
---

<Section
  id="sponsors"
  labelledBy="sponsors-heading"
  width="wide"
  padding="none"
  style="padding: 2rem 2rem 5rem;"
>
  <div class="sponsors-header-wrap">
    <SectionHeader
      id="sponsors-heading"
      title="Sponsors"
      subtitle="Thank you to the organizations backing HackMI. Interested in joining them?"
    />
  </div>

  <div class="sponsor-tiers">
    {
      TIER_DISPLAY.map(({ key, heading, totalSlots, shape }) => (
        <SponsorTier
          heading={heading}
          headingId={`tier-${key}-heading`}
          logos={sponsorLogosByTier[key]}
          totalSlots={totalSlots ?? sponsorLogosByTier[key].length}
          layout={key}
          shape={shape}
          slotLabel={`${heading} sponsor`}
        />
      ))
    }
  </div>

  <SponsorCTA />
  <BuiltByRow />
</Section>

<style>
  .sponsors-header-wrap :global(.section-subtitle) {
    text-transform: uppercase;
    max-width: 640px;
  }

  .sponsor-tiers {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }
</style>
