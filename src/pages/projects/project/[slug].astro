---
import {
  getProject,
  getProjectSlugs,
  urlFor,
  portableTextToPlainText,
  truncatePlainText,
  type HackathonProject,
} from "../../../lib/sanity";
import PageLayout from "../../../layouts/PageLayout.astro";
import { PortableText } from "astro-portabletext";
import { withBase } from "../../../data/nav";

export async function getStaticPaths() {
  const slugs = await getProjectSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
if (!slug) return Astro.redirect("/404");

const project: HackathonProject | null = await getProject(slug);
if (!project) return Astro.redirect("/404");
const base = import.meta.env.BASE_URL;

const descriptionBlocks = project.description ?? [];
const hasDescription = descriptionBlocks.length > 0;
const metaDescription =
  truncatePlainText(portableTextToPlainText(descriptionBlocks), 160) ||
  project.title;
---

<PageLayout
  title={project.title}
  description={metaDescription}
  mainClass="content-page"
>
  <div class="page-container">
    <header class="project-header">
      <div class="meta">
        {
          project.team?.slug?.current && (
            <a
              href={withBase(
                base,
                `/projects/team/${project.team.slug.current}/`,
              )}
              class="team-link"
            >
              {project.team.name}
            </a>
          )
        }
        {project.track && <span class="track"> • {project.track}</span>}
      </div>
      <h1 class="project-title">{project.title}</h1>
    </header>

    {
      project.mainImage && (
        <div class="hero-image">
          <img
            src={urlFor(project.mainImage).width(1200).url()}
            alt={project.title}
            loading="eager"
            decoding="async"
          />
        </div>
      )
    }

    <div
      class:list={[
        "project-grid",
        { "project-grid--no-description": !hasDescription },
      ]}
    >
      {
        hasDescription && (
          <div class="main-content">
            <div class="description">
              <PortableText value={descriptionBlocks} />
            </div>
          </div>
        )
      }

      <aside class="sidebar">
        {
          project.technologies && (
            <div class="sidebar-block">
              <h3>Tech Stack</h3>
              <div class="tag-list">
                {project.technologies.map((tech: string) => (
                  <span class="tag-chip tag-chip--lg">{tech}</span>
                ))}
              </div>
            </div>
          )
        }

        <div class="sidebar-block links">
          <h3>Links</h3>
          {
            project.githubUrl && (
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="detail-action detail-action--github"
              >
                View on GitHub
              </a>
            )
          }
          {
            project.demoUrl && (
              <a
                href={project.demoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="detail-action detail-action--demo"
              >
                Live Demo
              </a>
            )
          }
          {
            project.videoUrl && (
              <a
                href={project.videoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="detail-action detail-action--video"
              >
                Watch Demo Video
              </a>
            )
          }
        </div>
      </aside>
    </div>
  </div>
</PageLayout>

<style>
  .project-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .meta {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--color-text-dim);
  }

  .team-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 700;
  }

  .team-link:hover {
    text-decoration: underline;
  }

  .project-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
  }

  .hero-image {
    width: 100%;
    max-height: 600px;
    border-radius: 1.5rem;
    overflow: hidden;
    margin-bottom: 4rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: var(--surface-glass-raised-bg);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
  }

  .project-grid--no-description {
    grid-template-columns: 1fr;
    max-width: 28rem;
    margin-inline: auto;
  }

  .description {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .description :global(p) {
    margin-bottom: 1.5rem;
  }

  .sidebar-block {
    background: var(--surface-glass-raised-bg);
    padding: 1.5rem;
    border-radius: 1rem;
    margin-bottom: 2rem;
    border: 1px solid var(--color-border);
    backdrop-filter: blur(var(--surface-glass-blur));
    -webkit-backdrop-filter: blur(var(--surface-glass-blur));
  }

  .sidebar-block h3 {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .detail-action {
    display: block;
    text-align: center;
    padding: 0.8rem;
    border-radius: 0.6rem;
    text-decoration: none;
    font-weight: 700;
    transition:
      background var(--duration-fast) ease,
      filter var(--duration-fast) ease;
  }

  .detail-action--github {
    background: #333;
    color: white;
  }

  .detail-action--demo {
    background: var(--color-primary-button);
    color: white;
  }

  .detail-action--video {
    background: #e11d48;
    color: white;
  }

  .detail-action:hover {
    filter: brightness(1.2);
  }

  @media (max-width: 900px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      order: -1;
    }
  }
</style>
