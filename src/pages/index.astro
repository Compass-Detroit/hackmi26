---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThreeBackground from '../components/ThreeBackground.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import EventAbout from '../components/EventAbout.astro';
import SponsorCTA from '../components/SponsorCTA.astro';
import EventDetails from '../components/EventDetails.astro';
import Logistics from '../components/Logistics.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Hack Michigan 2026 - Detroit's Premier Engineering Event">
  <ThreeBackground />
  <Navigation />
  <Hero />
  <EventAbout />
  <SponsorCTA />
  <EventDetails />
  <Logistics />
  <FinalCTA />
  <Footer />
</BaseLayout>
