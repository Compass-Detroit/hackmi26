---
import {
  getHackathonProjectSlugs,
  getHackathonProject,
  urlFor,
} from "../../../lib/sanity";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ThreeBackground from "../../../components/ThreeBackground.astro";
import Navigation from "../../../components/Navigation.astro";
import Footer from "../../../components/Footer.astro";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
  const slugs = await getHackathonProjectSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const project = await getHackathonProject(slug);

if (!project) {
  return Astro.redirect("/404");
}

const descriptionBlocks = Array.isArray(project.description)
  ? project.description
  : [];
const hasDescription = descriptionBlocks.length > 0;
---

<BaseLayout title={project.title} description={project.title}>
  <ThreeBackground />
  <Navigation />

  <main id="main-content" class="project-detail-page" tabindex="-1">
    <div class="container">
      <header class="project-header">
        <div class="meta">
          {
            project.team?.slug?.current && (
              <a
                href={`/hackathon/team/${project.team.slug.current}/`}
                class="team-link"
              >
                {project.team.name}
              </a>
            )
          }
          {project.track && <span class="track"> • {project.track}</span>}
        </div>
        <h1 class="project-title">{project.title}</h1>
      </header>

      {
        project.mainImage && (
          <div class="hero-image">
            <img
              src={urlFor(project.mainImage).width(1200).url()}
              alt={project.title}
            />
          </div>
        )
      }

      <div
        class:list={[
          "project-grid",
          { "project-grid--no-description": !hasDescription },
        ]}
      >
        {
          hasDescription && (
            <div class="main-content">
              <div class="description">
                <PortableText value={descriptionBlocks} />
              </div>
            </div>
          )
        }

        <aside class="sidebar">
          {
            project.technologies && (
              <div class="sidebar-block">
                <h3>Tech Stack</h3>
                <div class="tags">
                  {project.technologies.map((tech: string) => (
                    <span class="tag">{tech}</span>
                  ))}
                </div>
              </div>
            )
          }

          <div class="sidebar-block links">
            <h3>Links</h3>
            {
              project.githubUrl && (
                <a
                  href={project.githubUrl}
                  target="_blank"
                  class="btn btn-github"
                >
                  View on GitHub
                </a>
              )
            }
            {
              project.demoUrl && (
                <a href={project.demoUrl} target="_blank" class="btn btn-demo">
                  Live Demo
                </a>
              )
            }
            {
              project.videoUrl && (
                <a
                  href={project.videoUrl}
                  target="_blank"
                  class="btn btn-video"
                >
                  Watch Demo Video
                </a>
              )
            }
          </div>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .project-detail-page {
    padding-top: calc(var(--nav-height) + 4rem);
    min-height: 100vh;
    padding-bottom: 5rem;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .project-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .meta {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--color-text-dim);
  }
  .team-link {
    color: var(--color-primary, #6366f1);
    text-decoration: none;
    font-weight: 700;
  }
  .team-link:hover {
    text-decoration: underline;
  }
  .project-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
  }
  .hero-image {
    width: 100%;
    max-height: 600px;
    border-radius: 1.5rem;
    overflow: hidden;
    margin-bottom: 4rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .project-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
  }
  .project-grid--no-description {
    grid-template-columns: 1fr;
    max-width: 28rem;
    margin-inline: auto;
  }
  .description {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text);
  }
  .description :global(p) {
    margin-bottom: 1.5rem;
  }
  .sidebar-block {
    background: rgba(255, 255, 255, 0.03);
    padding: 1.5rem;
    border-radius: 1rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .sidebar-block h3 {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.3rem 0.6rem;
    border-radius: 0.4rem;
    font-size: 0.85rem;
  }
  .links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .btn {
    display: block;
    text-align: center;
    padding: 0.8rem;
    border-radius: 0.6rem;
    text-decoration: none;
    font-weight: 700;
    transition: background 0.2s ease;
  }
  .btn-github {
    background: #333;
    color: white;
  }
  .btn-demo {
    background: var(--color-primary, #6366f1);
    color: white;
  }
  .btn-video {
    background: #e11d48;
    color: white;
  }
  .btn:hover {
    filter: brightness(1.2);
  }

  @media (max-width: 900px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
    .sidebar {
      order: -1;
    }
  }
</style>
