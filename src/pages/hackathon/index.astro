---
import {
  getProjects,
  urlFor,
  HACKATHON_CARD_DESCRIPTION_CHARS,
  portableTextToPlainText,
  truncatePlainText,
  type HackathonProjectPreview,
} from "../../lib/sanity";
import PageLayout from "../../layouts/PageLayout.astro";

const projects: HackathonProjectPreview[] = await getProjects();
---

<PageLayout
  title="Hackathon Projects - Hack Michigan"
  description="Discover the amazing projects built at Hack Michigan"
  mainClass="hackathon-page"
>
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Hackathon Submissions</h1>
      <p class="page-subtitle">
        Showcasing the creativity and innovation from our latest event.
      </p>
    </header>

    <div class="project-grid">
      {
        projects.length === 0 && (
          <p class="empty-state">
            Project submissions will appear here once teams start publishing.
            Watch this space.
          </p>
        )
      }
      {
        projects.map((project) => {
          const descriptionPlain = portableTextToPlainText(project.description);
          const descriptionPreview = truncatePlainText(
            descriptionPlain,
            HACKATHON_CARD_DESCRIPTION_CHARS,
          );
          return (
            <article class="project-card">
              <a
                href={`/hackathon/project/${project.slug.current}/`}
                class="card-link"
              >
                {project.mainImage && (
                  <div class="image-wrapper">
                    <img
                      src={urlFor(project.mainImage).width(600).url()}
                      alt={project.title}
                      loading="lazy"
                    />
                  </div>
                )}
              </a>
              <div class="content">
                {project.team?.slug?.current && (
                  <a
                    href={`/hackathon/team/${project.team.slug.current}/`}
                    class="team-badge"
                  >
                    {project.team.name}
                  </a>
                )}
                <a
                  href={`/hackathon/project/${project.slug.current}/`}
                  class="title-link"
                >
                  <h2>{project.title}</h2>
                </a>
                {descriptionPreview && (
                  <p class="description">{descriptionPreview}</p>
                )}

                <div class="tags">
                  {project.technologies?.map((tech) => (
                    <span class="tag">{tech}</span>
                  ))}
                </div>

                <div class="links">
                  {project.githubUrl && (
                    <a
                      href={project.githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Project on GitHub
                    </a>
                  )}
                  {project.demoUrl && (
                    <a
                      href={project.demoUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      See Our Demo
                    </a>
                  )}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</PageLayout>

<style>
  .hackathon-page {
    min-height: 100vh;
    padding: calc(var(--nav-height) + 2rem) 2rem 5rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-dim);
    max-width: 600px;
    margin: 0 auto;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-text-dim);
    font-size: 1.05rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--surface-glass-bg, rgb(30 41 59 / 55%));
  }

  .project-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 1rem;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      background 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.05);
  }

  .image-wrapper img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .content {
    padding: 1.5rem;
  }

  .team-badge {
    display: inline-block;
    background: var(--color-primary, #6366f1);
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-decoration: none;
    transition: filter 0.2s ease;
  }

  .team-badge:hover {
    filter: brightness(1.2);
  }

  .title-link {
    text-decoration: none;
    color: inherit;
  }

  .title-link:hover h2 {
    color: var(--color-primary, #6366f1);
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    transition: color 0.2s ease;
  }

  .description {
    color: var(--color-text-dim);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.2rem 0.5rem;
    border-radius: 0.3rem;
    font-size: 0.8rem;
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .links a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .links a:hover {
    border-color: var(--color-text);
  }
</style>
