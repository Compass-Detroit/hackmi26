---
/**
 * PageLayout — the shell every public page shares.
 *
 * Wraps BaseLayout (which owns <head>, meta, analytics, view transitions)
 * with the chrome that every page renders on top: the WebGL starfield,
 * the global nav, a focusable <main>, and the site footer.
 *
 * Pages stay declarative — they just drop their content into the default
 * slot and optionally extend <main> with an extra class or id via props.
 *
 *   ---
 *   import PageLayout from "../layouts/PageLayout.astro";
 *   ---
 *   <PageLayout title="..." description="..." mainClass="project-detail-page">
 *     <header>...</header>
 *     <section>...</section>
 *   </PageLayout>
 *
 * If a page needs to control head-level props, it passes them straight
 * through to BaseLayout (title, description, image, ogType).
 */
import BaseLayout from "./BaseLayout.astro";
import ThreeBackground from "../components/ThreeBackground.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
  /** Additional class on the <main> element (for page-specific layout CSS). */
  mainClass?: string;
}

const { title, description, image, ogType, mainClass } = Astro.props;

/**
 * Only forward props that were actually passed. With
 * `exactOptionalPropertyTypes`, forwarding `undefined` under a key that
 * BaseLayout types as optional-and-non-undefined is a TS error — omit
 * the key instead so BaseLayout's own defaults kick in.
 */
const baseLayoutProps = {
  ...(title !== undefined && { title }),
  ...(description !== undefined && { description }),
  ...(image !== undefined && { image }),
  ...(ogType !== undefined && { ogType }),
};
---

<BaseLayout {...baseLayoutProps}>
  <ThreeBackground />
  <Navigation />
  <main id="main-content" class={mainClass} tabindex="-1">
    <slot />
  </main>
  <Footer />
</BaseLayout>
