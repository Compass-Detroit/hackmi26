# Copy this file to `.env` and fill in values for local dev.
# Production values are configured in Vercel project settings.
#
# All `PUBLIC_*` vars are inlined into client bundles — never put secrets here.

# ---- Sanity CMS ------------------------------------------------------------
# The Astro site reads these at build time in `astro.config.mjs`.
# Defaults (if unset) fall back to the HackMI production project.
PUBLIC_SANITY_PROJECT_ID=f188znys
PUBLIC_SANITY_DATASET=production
# Optional safety switch: when true (and not in dev), build fails on Sanity fetch errors.
PUBLIC_SANITY_STRICT_MODE=false

# ---- Facebook Open Graph ---------------------------------------------------
# Optional. Used by `<meta property="fb:app_id">` in BaseLayout.
PUBLIC_FB_APP_ID=

# ---- Deploy trigger (server-only) -----------------------------------------
# Used by /deploy and /api/trigger-deploy in local dev + Vercel.
# Do NOT prefix with PUBLIC_. Keep these secret.
# N8N webhook endpoint that starts a production redeploy.
N8N_VERCEL_DEPLOY_WEBHOOK_URL=
# Optional shared passphrase required by proxy endpoint.
DEPLOY_TRIGGER_SECRET=

# ---- Sanity Studio (optional) ---------------------------------------------
# Only set these in `studio-hack-michigan-/.env` if the local Studio should
# point at a different dataset than the site (e.g. a `development` dataset).
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=
