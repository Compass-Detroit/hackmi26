{
  "name": "hackmichigan",
  "type": "module",
  "version": "1.1.1",
  "description": "Hack Michigan (HackMI) — marketing site and hackathon showcase for the Detroit tech corridor, built with Astro + Sanity.",
  "keywords": [
    "astro",
    "sanity",
    "hackathon",
    "detroit",
    "three.js",
    "typescript"
  ],
  "author": "Compass Detroit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Compass-Detroit/hackmi26"
  },
  "homepage": "https://hackmichigan.com",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.{css,astro}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,astro}\" --fix",
    "typecheck": "astro check",
    "verify": "npm run format:check && npm run lint && npm run lint:css && npm run typecheck && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@sanity/astro": "^3.3.1",
    "@sanity/image-url": "^2.1.1",
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.1.0",
    "astro-portabletext": "^0.13.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "astro-eslint-parser": "^1.4.0",
    "cheerio": "^1.2.0",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": ">=2.8.3"
    }
  }
}
