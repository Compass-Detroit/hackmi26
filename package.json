{
  "name": "hackmichigan",
  "type": "module",
  "version": "1.1.1",
  "description": "A dark-themed Astro portfolio/blog template with Three.js particles and modern animations",
  "keywords": [
    "astro",
    "theme",
    "blog",
    "portfolio",
    "dark-mode",
    "three.js",
    "typescript"
  ],
  "author": "kpab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kpab/astro-darkness"
  },
  "homepage": "https://hackmichigan.com",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.{css,astro}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,astro}\" --fix"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.1.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": ">=2.8.3"
    }
  }
}
